{
  "name": "qa-carrefour-webdriverio",
  "version": "1.0.0",
  "type": "commonjs",
  "description": "Automação de testes mobile com WebDriverIO, Appium e Allure Report para native-demo-app",
  "main": "index.js",
  "scripts": {
    "clean:allure": "rimraf allure-results",
    "test:android": "wdio run ./config/wdio.android.conf.js",
    "test:telas": "wdio run ./config/wdio.android.conf.js --spec ./tests/navegarTelasWebdriverio.test.js",
    "test:logar": "wdio run ./config/wdio.android.conf.js --spec ./tests/logarWebdriverio.test.js",
    "test:forms": "wdio run ./config/wdio.android.conf.js --spec ./tests/formsWebdriverio.test.js",
    "test:sign": "wdio run ./config/wdio.android.conf.js --spec ./tests/signUpWebdriverio.test.js",
    "test:swipe": "wdio run ./config/wdio.android.conf.js --spec ./tests/swipeWebdriverio.test.js",
    "report:generate": "allure generate allure-results --clean -o allure-report",
    "report:open": "allure open allure-report"
  },
  "dependencies": {},
  "devDependencies": {
    "@babel/core": "^7.22.0",
    "@babel/preset-env": "^7.22.0",
    "@wdio/allure-reporter": "^8.10.0",
    "@wdio/appium-service": "^8.10.0",
    "@wdio/cli": "^8.10.0",
    "@wdio/local-runner": "^8.10.0",
    "@wdio/mocha-framework": "^8.10.0",
    "@wdio/spec-reporter": "^8.10.0",
    "allure-commandline": "^2.22.0",
    "chai": "^4.3.7"
  }
}